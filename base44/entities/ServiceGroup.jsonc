{
  "name": "ServiceGroup",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "service",
        "product"
      ]
    },
    "color": {
      "type": "string",
      "default": "#FF6B9D"
    },
    "branch_id": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name",
    "type"
  ]
}