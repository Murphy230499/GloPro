{
  "name": "Treatment",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "group_id": {
      "type": "string"
    },
    "expiry_months": {
      "type": "number",
      "default": 0
    },
    "expiry_days": {
      "type": "number",
      "default": 0
    },
    "price": {
      "type": "number",
      "default": 0
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "service_id": {
            "type": "string"
          },
          "service_name": {
            "type": "string"
          },
          "sessions": {
            "type": "number"
          },
          "unit_price_retail": {
            "type": "number"
          },
          "unit_price_in_treatment": {
            "type": "number"
          }
        }
      }
    },
    "description": {
      "type": "string"
    },
    "branch_id": {
      "type": "string"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "image_url": {
      "type": "string"
    },
    "sort_order": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}